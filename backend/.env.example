# Copier vers .env et renseigner les valeurs (ne jamais committer .env).
# Les variables sont lues par Spring Boot si vous les exportez dans l'environnement
# ou si vous utilisez un outil qui charge .env au démarrage.

DB_URL=
DB_USERNAME=
DB_PASSWORD=

# Minimum 32 caractères UTF-8 pour HS256 (voir JwtService).
JWT_SECRET=
